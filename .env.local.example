# ---------------------------------------------------------------------------
# CogniForge — local development template (faster iteration)
#   cp .env.local.example .env
# ---------------------------------------------------------------------------

LLM_ROUTER=minimax
MODEL_PRESET=minimax_default

MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimaxi.com/v1
OPENROUTER_API_KEY=
OPENAI_API_KEY=

REDIS_URL=redis://localhost:6379/0
OUTPUT_DIR=./outputs

# Lighter loop gates for dev (matches config/settings.yaml)
MAX_MACRO_ITER=1000
TARGET_ACCURACY=0.95
MIN_MACRO_ITER=1
CONSECUTIVE_PASS_ROUNDS=1

# Exam scale: prefer settings.yaml (50/30) unless overridden here
# FIRST_ROUND_TOTAL_QUESTIONS=50
# FOCUSED_ROUND_QUESTIONS=30

CLOSED_BOOK_EXAM=1
STUDENT_NOTES_MAX_CHARS=2500
STUDENT_NOTES_STUDY_MAX_CHARS=8000
STUDENT_MATERIAL_STUDY_MAX_CHARS=6000
CURRICULUM_PAGES_PER_ROUND=12
CURRICULUM_ADVANCE_ACCURACY=0.85
DIFFICULTY_ADVANCE_ACCURACY=0.90
DIFFICULTY_RETREAT_ACCURACY=0.50
JUDGE_EVIDENCE_ONLY=1
EVIDENCE_CAP_SCORE=0.78

SINGLE_LLM_TIMEOUT=120
EXAM_BATCH_TIMEOUT=600
MACRO_ITER_TIMEOUT=3600

LOG_LEVEL=INFO
LOG_LLM=0
LOG_PROGRESS_EVERY=5

CRAWL_ENABLED=1
CRAWL_MAX_PAGES=100
CRAWL_INCLUDE_IMAGES=1
