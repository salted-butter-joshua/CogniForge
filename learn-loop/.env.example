MAX_MACRO_ITER=1000
TARGET_ACCURACY=0.95
QUESTIONS_PER_PERSONA=10
FIRST_ROUND_TOTAL_QUESTIONS=150
FOCUSED_ROUND_QUESTIONS=50
JUDGE_BATCH_SIZE=10
STUDENT_ANSWER_BATCH_SIZE=10

MIN_MACRO_ITER=3
CONSECUTIVE_PASS_ROUNDS=2
CLOSED_BOOK_EXAM=1
STUDENT_NOTES_MAX_CHARS=2500
STUDENT_NOTES_STUDY_MAX_CHARS=8000
STUDENT_MATERIAL_STUDY_MAX_CHARS=6000
CURRICULUM_PAGES_PER_ROUND=12
JUDGE_EVIDENCE_ONLY=1
