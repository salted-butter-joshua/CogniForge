# ---------------------------------------------------------------------------
# CogniForge — environment template
#   cp .env.example .env
#   Fill in API keys locally. Never commit .env.
# ---------------------------------------------------------------------------

# --- LLM routing ---
LLM_ROUTER=litellm
MODEL_PRESET=minimax_default

# --- API keys (set at least one for your chosen router) ---
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimaxi.com/v1
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- Infrastructure ---
REDIS_URL=redis://localhost:6379/0
OUTPUT_DIR=./outputs

# --- Loop termination ---
MAX_MACRO_ITER=1000
TARGET_ACCURACY=0.95
MIN_MACRO_ITER=3
CONSECUTIVE_PASS_ROUNDS=2

# --- Exam scale (overrides config/settings.yaml when set) ---
# Dev-friendly defaults live in settings.yaml (50/30 questions).
# Uncomment to force production-scale exams:
# QUESTIONS_PER_PERSONA=10
# FIRST_ROUND_TOTAL_QUESTIONS=150
# FOCUSED_ROUND_QUESTIONS=50
# JUDGE_BATCH_SIZE=10
# STUDENT_ANSWER_BATCH_SIZE=10

# --- Learning realism ---
CLOSED_BOOK_EXAM=1
STUDENT_NOTES_MAX_CHARS=2500
STUDENT_NOTES_STUDY_MAX_CHARS=8000
STUDENT_MATERIAL_STUDY_MAX_CHARS=6000
CURRICULUM_PAGES_PER_ROUND=12
CURRICULUM_ADVANCE_ACCURACY=0.85
DIFFICULTY_ADVANCE_ACCURACY=0.90
DIFFICULTY_RETREAT_ACCURACY=0.50
JUDGE_EVIDENCE_ONLY=1
JUDGE_EVIDENCE_MAX_CHARS=12000
EVIDENCE_CAP_SCORE=0.78
# 语义宽松：1=中心意思一致即对，跳过词面惩罚；0=启用 evidence 词面外推 cap
JUDGE_SEMANTIC_LENIENT=1
# 评分/作答随机性（0~1.5；语义判题建议 Judge≈0.2，作答≈0.25）
JUDGE_TEMPERATURE=0.2
STUDENT_EXAM_TEMPERATURE=0.25

# --- Timeouts (seconds) ---
SINGLE_LLM_TIMEOUT=120
EXAM_BATCH_TIMEOUT=600
MACRO_ITER_TIMEOUT=3600

# --- Logging ---
LOG_LEVEL=INFO
LOG_LLM=0
LOG_PROGRESS_EVERY=5

# --- Crawl ---
CRAWL_ENABLED=1
CRAWL_MAX_PAGES=100
CRAWL_INCLUDE_IMAGES=1

# --- Docker Compose CLI defaults (optional) ---
LOOP_URLS=https://docs.python.org/3/tutorial/index.html
LOOP_GOAL=Master core Python tutorial concepts
LOOP_TASK_ID=demo-001
